# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2

# Ollama (remote, OpenAI-compatible)
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

# App config
MAX_PDF_SIZE_MB=20
MAX_PDF_PAGES=20
# RATE_LIMIT_MAX=10              # Max reviews per user per window (default: 10, admins exempt)
# RATE_LIMIT_WINDOW_MS=3600000   # Rate limit window in ms (default: 3600000 = 1 hour)

# Auth (Keycloak)
AUTH_SECRET=              # REQUIRED. Generate: openssl rand -base64 32
AUTH_KEYCLOAK_ID=proposal-checker
AUTH_KEYCLOAK_SECRET=     # REQUIRED. From Keycloak client Credentials tab
AUTH_KEYCLOAK_ISSUER=https://keycloak.aet.cit.tum.de/realms/tum
AUTH_TRUST_HOST=true
# AUTH_URL=https://<production-domain>  # Set in production .env.local

# Role mapping: Keycloak role name → app role. Defaults to the app role name.
# AUTH_ROLE_ADMIN=admin
# AUTH_ROLE_PHD=phd
# AUTH_ROLE_STUDENT=student

# Email notifications (optional — disabled when SMTP_HOST is not set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587                   # Default: 587 (STARTTLS). Use 465 for implicit TLS.
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com   # Defaults to SMTP_USER if not set

# Database (required for persistent reviews)
DATABASE_URL=postgres://proposal_checker:proposal_checker@localhost:5432/proposal_checker
